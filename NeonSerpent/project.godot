; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="NeonSerpent"
config/description="蛇卫核心 — 贪吃蛇 × 吸血鬼幸存者 × 塔防 · 赛博霓虹风"
config/version="0.1.0"
run/main_scene="res://ui/menus/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

EventBus="*res://common/autoloads/event_bus.gd"
GameState="*res://common/autoloads/game_state.gd"
ObjectPool="*res://common/autoloads/object_pool.gd"
AudioManager="*res://common/autoloads/audio_manager.gd"
MCPGameBridge="res://addons/godot_mcp/game_bridge/mcp_game_bridge.gd"

[debug]

gdscript/warnings/untyped_declaration=1

[display]

window/size/viewport_width=768
window/size/viewport_height=768
window/size/resizable=true
window/size/fullscreen=false

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_mcp/plugin.cfg")

[godot_mcp]

bind_mode=0
custom_bind_ip=""
port_override_enabled=false
port_override=6550

